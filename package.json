{
  "name": "cm-framework",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Framework full stack CM base sur JavaScript, TypeScript, Python, HTML et CSS.",
  "bin": {
    "cm": "./bin/cm.mjs"
  },
  "scripts": {
    "dev": "node ./bin/cm.mjs serve",
    "build": "node ./bin/cm.mjs build",
    "doctor": "node ./bin/cm.mjs doctor",
    "install:cm": "node ./bin/cm.mjs install",
    "test": "node --test tests"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
